import { Button, VerticalBox, HorizontalBox, GroupBox, LineEdit, ListView, CheckBox, TextEdit } from "std-widgets.slint";

// Uma linha do catálogo rico. Preenchida pelo binário (raiz de composição) a
// partir do `GameMeta` do core; campos já formatados para exibição.
struct GameRow {
    title: string,
    game-id: string,
    media: string,
    size: string,
    // Nome do arquivo da ISO — exibido no editor de metadados (o `title` pode ser
    // um título derivado/sobrescrito, então guardamos o arquivo cru à parte).
    file-name: string,
}

// Janela funcional: seleção do diretório-alvo, status do servidor, IP/instruções
// de conexão, catálogo e um controle ÚNICO de servidor (ativar/desativar). A
// lógica de negócio vive no core/infra; aqui só apresentação e callbacks (a UI
// nunca fala com a infra direto — o binário é a raiz de composição).
//
// i18n híbrido (ver plans/fase-3-i18n.md): as strings ESTÁTICAS aqui usam
// `@tr("English source")` (traduções `.po` bundladas). As strings DINÂMICAS
// (status, IP, resumo, dicas, mensagens, notas) são montadas em Rust via fluent
// e entram por properties — por isso seus defaults são "" (o binário preenche).
export component AppWindow inherits Window {
    title: @tr("oplhost — OPL server");
    // Ícone da janela embutido em tempo de compilação. Aparece na barra de
    // título/taskbar mesmo em `cargo run` (sem .desktop instalado). Em alguns
    // compositores Wayland a taskbar usa o app_id do .desktop, não este ícone —
    // por isso o .desktop (Icon=oplhost) continua sendo necessário pós-instalação.
    icon: @image-url("../packaging/oplhost.png");
    preferred-width: 600px;
    // A lista do catálogo é `vertical-stretch` (sem altura natural fixa), então a
    // janela nasce com ESTA `preferred-height` no primeiro show — não com o mínimo
    // derivado do layout. Por isso ela precisa caber o conteúdo do IDIOMA MAIS
    // LONGO (pt-BR, cujo aviso de SMBv1 quebra em mais linhas que o en-US): com
    // 740px o botão inferior nascia cortado em pt-BR e só reaparecia ao entrar/sair
    // de Configurações (que força um relayout e cresce a janela). Com folga, o
    // botão e o aviso cabem já no primeiro show em ambos os idiomas.
    preferred-height: 820px;
    min-width: 520px;
    // Sem min-height explícito de propósito: o Slint deriva o mínimo da janela do
    // layout (lista no seu `min-height` + tudo que é fixo); ao redimensionar à mão
    // a lista encolhe primeiro, preservando aviso e botão.

    // Dinâmicas (preenchidas pelo binário via fluent) → default "".
    in property <string> status-text: "";
    in property <string> ip-text: "";
    in property <string> catalog-summary: "";
    in property <[GameRow]> catalog-rows: [];
    in property <string> message-text: "";
    in-out property <string> dir-path: "";
    in property <bool> busy: false;
    // Estado real do servidor: a config do OPL está aplicada (servindo)? Dirige o
    // botão único de toggle (rótulo/ação) de forma coerente com o status.
    in property <bool> server-active: false;
    // Painel de Configurações sobreposto à tela principal (gear no cabeçalho).
    in-out property <bool> show-settings: false;

    // ----- Editor de metadados do jogo (overlay in-place, como o de Settings) -----
    // Aberto ao clicar numa linha do catálogo; grava em CFG/<GameID>.cfg (info do
    // OPL). Não reflui a tela principal — a substitui enquanto aberto.
    in-out property <bool> show-game-editor: false;
    // Índice da linha clicada (para o binário atualizar o título após salvar).
    in-out property <int> editor-index: -1;
    // Cabeçalho do editor: identidade do jogo (read-only).
    in property <image> editor-cover;
    in property <bool> editor-has-cover: false;
    in property <string> editor-file-name: "";
    in property <string> editor-game-id: "";
    in property <string> editor-media: "";
    // Sem Game ID o OPL não tem como nomear o .cfg → editor abre só-leitura.
    in property <bool> editor-can-edit: false;
    // Aviso contextual do editor (dinâmico, montado em Rust).
    in property <string> editor-note: "";
    // Campos editáveis (espelham as 5 chaves de info do OPL).
    in-out property <string> field-title: "";
    in-out property <string> field-genre: "";
    in-out property <string> field-release: "";
    in-out property <string> field-developer: "";
    in-out property <string> field-description: "";
    // Modos de compatibilidade do OPL (bits de $Compatibility no mesmo .cfg).
    in-out property <bool> compat-mode1: false;
    in-out property <bool> compat-mode2: false;
    in-out property <bool> compat-mode3: false;
    in-out property <bool> compat-mode4: false;
    in-out property <bool> compat-mode5: false;
    in-out property <bool> compat-mode6: false;
    // Dica contextual sobre o diretório-alvo (dinâmica, montada em Rust).
    in property <string> dir-hint: "";
    in property <bool> dir-hint-warning: false;
    // Acesso opcional usuário/senha. Guest (acesso livre) é o padrão.
    in-out property <bool> auth-enabled: false;
    in-out property <string> auth-password: "";
    in property <string> auth-username: "";
    // Backend de storage: false = SMB (Samba, padrão), true = UDPBD (BDM). O SMB
    // serve a pasta em `dir-path`; o UDPBD serve o block device/imagem em
    // `udpbd-device` (modelos diferentes — ver plans/fase-3-udpbd-backend.md).
    in-out property <bool> backend-udpbd: false;
    in-out property <string> udpbd-device: "";

    callback toggle-server-clicked();
    callback choose-dir-clicked();
    callback download-art-clicked();
    callback dir-path-edited();
    // Troca de backend (persiste a escolha e reavalia o status).
    callback backend-changed();
    // Edição do caminho do device/imagem do UDPBD (persiste).
    callback udpbd-device-edited();
    // Clique numa linha do catálogo (índice) → o binário carrega o info e abre o editor.
    callback game-clicked(int);
    // Salvar os metadados editados no CFG/<GameID>.cfg do jogo selecionado.
    callback save-game-info-clicked();

    VerticalBox {
        padding: 12px;
        spacing: 10px;

        // Cabeçalho: título + botão de Configurações (alterna o painel).
        HorizontalBox {
            spacing: 8px;
            Text {
                text: root.show-game-editor ? @tr("Edit metadata")
                    : root.show-settings ? @tr("Settings") : "oplhost";
                font-size: 24px;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            // O gear some no editor (que tem seus próprios botões Cancelar/Salvar).
            if !root.show-game-editor: Button {
                text: root.show-settings ? @tr("← Back") : @tr("⚙ Settings");
                enabled: !root.busy;
                clicked => { root.show-settings = !root.show-settings; }
            }
        }

        // ===================== TELA PRINCIPAL =====================
        if !root.show-settings && !root.show-game-editor: VerticalLayout {
            vertical-stretch: 1;
            spacing: 10px;

            // SMB serve uma PASTA. UDPBD serve um BLOCK DEVICE/IMAGEM (modelos
            // diferentes) → o alvo troca conforme o backend escolhido nos Settings.
            if !root.backend-udpbd: GroupBox {
                title: @tr("OPL target directory");
                VerticalBox {
                    HorizontalBox {
                        spacing: 8px;
                        LineEdit {
                            placeholder-text: @tr("/path/to/disk-or-folder");
                            text <=> root.dir-path;
                            enabled: !root.busy;
                            edited => { root.dir-path-edited(); }
                        }
                        Button {
                            text: @tr("Choose folder…");
                            enabled: !root.busy;
                            clicked => { root.choose-dir-clicked(); }
                        }
                    }
                    Text {
                        text: root.dir-hint;
                        font-size: 12px;
                        wrap: word-wrap;
                        color: root.dir-hint-warning ? #b58900 : #888;
                    }
                }
            }
            if root.backend-udpbd: GroupBox {
                title: @tr("UDPBD block device or image");
                VerticalBox {
                    LineEdit {
                        placeholder-text: @tr("/dev/sdX or /path/to/ps2.img");
                        text <=> root.udpbd-device;
                        enabled: !root.busy;
                        edited => { root.udpbd-device-edited(); }
                    }
                    Text {
                        text: @tr("UDPBD serves a raw FAT32/exFAT block device or image (not a folder), over UDP port 48573. A /dev/… path needs your password; an image file does not.");
                        font-size: 12px;
                        wrap: word-wrap;
                        color: #888;
                    }
                }
            }

            GroupBox {
                title: @tr("Server");
                VerticalBox {
                    Text { text: @tr("Status: {}", root.status-text); }
                    Text { text: @tr("Local IP (enter in OPL): {}", root.ip-text); }
                }
            }

            GroupBox {
                title: @tr("Catalog");
                vertical-stretch: 1;
                VerticalBox {
                    spacing: 6px;
                    Text {
                        text: root.catalog-summary;
                        font-weight: 600;
                    }
                    if root.catalog-rows.length > 0: Text {
                        text: @tr("Click a game to edit its metadata (OPL Information screen).");
                        font-size: 12px;
                        color: #888;
                    }
                    ListView {
                        min-height: 80px;
                        vertical-stretch: 1;
                        for row[idx] in root.catalog-rows: Rectangle {
                            height: 26px;
                            background: touch.has-hover ? #00000014
                                : Math.mod(idx, 2) == 0 ? transparent : #00000008;
                            // Clicar na linha abre o editor de metadados do jogo.
                            touch := TouchArea {
                                enabled: !root.busy;
                                clicked => { root.game-clicked(idx); }
                            }
                            HorizontalBox {
                                padding-left: 6px;
                                // Gutter à direita pro scrollbar nativo do ListView
                                // não cobrir a coluna de tamanho.
                                padding-right: 18px;
                                padding-top: 2px;
                                padding-bottom: 2px;
                                spacing: 8px;
                                Text {
                                    text: row.title;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.game-id;
                                    width: 96px;
                                    color: #888;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.media;
                                    width: 36px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.size;
                                    width: 72px;
                                    horizontal-alignment: right;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    Button {
                        text: @tr("Download covers");
                        // Só faz sentido com catálogo carregado.
                        enabled: !root.busy && root.catalog-rows.length > 0;
                        clicked => { root.download-art-clicked(); }
                    }
                }
            }

            // Área de status/erro com altura reservada: mostrar ou ocultar a
            // mensagem não reflui o layout (não empurra o aviso nem o botão).
            Rectangle {
                height: 36px;
                Text {
                    width: 100%;
                    text: root.message-text;
                    wrap: word-wrap;
                    overflow: elide;
                    vertical-alignment: center;
                    color: #d33682;
                }
            }

            if !root.backend-udpbd: Text {
                text: @tr("Warning: OPL requires SMBv1 (a legacy protocol). The app re-enables it in an isolated share and opens port 445 — asking for your password once.");
                wrap: word-wrap;
                color: #b58900;
            }
            if root.backend-udpbd: Text {
                text: @tr("UDPBD supervises the udpbd-server process serving your device over UDP 48573. It requires the udpbd-server binary installed and OPL built with BDM/UDPBD support.");
                wrap: word-wrap;
                color: #b58900;
            }

            // Controle ÚNICO do servidor: o mesmo botão ativa ou desativa,
            // conforme o estado real (sem os dois botões conflitantes de antes).
            Button {
                text: root.server-active ? @tr("Deactivate and revert") : @tr("Activate server");
                primary: !root.server-active;
                enabled: !root.busy;
                clicked => { root.toggle-server-clicked(); }
            }
        }

        // ===================== CONFIGURAÇÕES =====================
        if root.show-settings: VerticalLayout {
            vertical-stretch: 1;
            spacing: 10px;

            GroupBox {
                title: @tr("Storage backend");
                VerticalBox {
                    spacing: 6px;
                    CheckBox {
                        text: @tr("Serve via UDPBD (BDM) instead of SMB (Samba)");
                        checked <=> root.backend-udpbd;
                        enabled: !root.busy;
                        toggled => { root.backend-changed(); }
                    }
                    Text {
                        text: @tr("SMB (default) serves a folder to any OPL out of the box. UDPBD is faster and lighter on the PS2, but serves a raw block device/image and needs an OPL build with BDM/UDPBD support.");
                        font-size: 12px;
                        wrap: word-wrap;
                        color: #888;
                    }
                }
            }

            // Acesso usuário/senha só existe no SMB — o UDPBD não tem autenticação.
            if !root.backend-udpbd: GroupBox {
                title: @tr("Share access");
                VerticalBox {
                    spacing: 6px;
                    CheckBox {
                        text: @tr("Require username and password (instead of open access)");
                        checked <=> root.auth-enabled;
                        enabled: !root.busy;
                    }
                    if root.auth-enabled: VerticalBox {
                        spacing: 6px;
                        // Empacota no topo: sem isto o LineEdit esticava na vertical
                        // e desperdiçava a tela (feedback 2026-06-28).
                        alignment: start;
                        Text {
                            text: @tr("User: {}  —  in OPL, configure SMB with this user and the password below.", root.auth-username);
                            font-size: 12px;
                            color: #888;
                        }
                        LineEdit {
                            placeholder-text: @tr("Share password");
                            input-type: password;
                            text <=> root.auth-password;
                            enabled: !root.busy;
                            // Mantém a altura de UMA linha (não estica na vertical).
                            vertical-stretch: 0;
                        }
                        Text {
                            text: @tr("Without this the share is open (guest): anyone on your local network can read and write. The password is stored in the system Samba (smbpasswd).");
                            wrap: word-wrap;
                            font-size: 12px;
                            color: #b58900;
                        }
                    }
                }
            }

            if !root.backend-udpbd: Text {
                text: @tr("Access changes take effect the next time you activate the server (or reactivate to apply now).");
                font-size: 12px;
                wrap: word-wrap;
                color: #888;
            }

            // Empurra o conteúdo das Configurações para o topo.
            Rectangle { vertical-stretch: 1; }
        }

        // ===================== EDITOR DE METADADOS =====================
        // Grava os 5 campos que o OPL exibe na tela "Informações" em
        // CFG/<GameID>.cfg (preservando configs de compatibilidade do jogo).
        if root.show-game-editor: VerticalLayout {
            vertical-stretch: 1;
            spacing: 10px;

            GroupBox {
                title: @tr("Game");
                HorizontalBox {
                    spacing: 12px;
                    alignment: start;
                    if root.editor-has-cover: Image {
                        source: root.editor-cover;
                        width: 90px;
                        height: 128px;
                        image-fit: contain;
                    }
                    VerticalLayout {
                        alignment: start;
                        spacing: 4px;
                        Text {
                            text: root.editor-file-name;
                            font-weight: 600;
                            wrap: word-wrap;
                        }
                        Text {
                            text: @tr("Game ID: {}", root.editor-game-id == "" ? "—" : root.editor-game-id);
                            font-size: 12px;
                            color: #888;
                        }
                        Text {
                            text: @tr("Media: {}", root.editor-media);
                            font-size: 12px;
                            color: #888;
                        }
                    }
                }
            }

            if root.editor-can-edit: GroupBox {
                title: @tr("Information (shown in OPL)");
                vertical-stretch: 1;
                VerticalBox {
                    spacing: 6px;
                    Text {
                        text: @tr("Title");
                        font-size: 12px;
                        color: #888;
                    }
                    LineEdit {
                        placeholder-text: @tr("Overrides the name shown in OPL");
                        text <=> root.field-title;
                        enabled: !root.busy;
                    }
                    Text {
                        text: @tr("Genre");
                        font-size: 12px;
                        color: #888;
                    }
                    LineEdit {
                        text <=> root.field-genre;
                        enabled: !root.busy;
                    }
                    Text {
                        text: @tr("Release");
                        font-size: 12px;
                        color: #888;
                    }
                    LineEdit {
                        placeholder-text: @tr("e.g. 2005-03-22, 2005 or \"June 24, 2007\"");
                        text <=> root.field-release;
                        enabled: !root.busy;
                    }
                    Text {
                        text: @tr("Developer");
                        font-size: 12px;
                        color: #888;
                    }
                    LineEdit {
                        text <=> root.field-developer;
                        enabled: !root.busy;
                    }
                    Text {
                        text: @tr("Description");
                        font-size: 12px;
                        color: #888;
                    }
                    TextEdit {
                        text <=> root.field-description;
                        enabled: !root.busy;
                        wrap: word-wrap;
                        min-height: 64px;
                        vertical-stretch: 1;
                    }
                    Text {
                        text: @tr("Each field accepts up to 255 characters (OPL limit). An empty field removes the data from the game.");
                        font-size: 12px;
                        wrap: word-wrap;
                        color: #888;
                    }
                }
            }

            if root.editor-can-edit: GroupBox {
                title: @tr("Compatibility modes (OPL)");
                VerticalBox {
                    spacing: 4px;
                    CheckBox {
                        text: @tr("Mode 1: Accurate Reads");
                        checked <=> root.compat-mode1;
                        enabled: !root.busy;
                    }
                    CheckBox {
                        text: @tr("Mode 2: Synchronous Mode");
                        checked <=> root.compat-mode2;
                        enabled: !root.busy;
                    }
                    CheckBox {
                        text: @tr("Mode 3: Unhook Syscalls");
                        checked <=> root.compat-mode3;
                        enabled: !root.busy;
                    }
                    CheckBox {
                        text: @tr("Mode 4: Skip Videos");
                        checked <=> root.compat-mode4;
                        enabled: !root.busy;
                    }
                    CheckBox {
                        text: @tr("Mode 5: Emulate DVD-DL");
                        checked <=> root.compat-mode5;
                        enabled: !root.busy;
                    }
                    CheckBox {
                        text: @tr("Mode 6: Disable IGR");
                        checked <=> root.compat-mode6;
                        enabled: !root.busy;
                    }
                    Text {
                        text: @tr("Per-game OPL load fixes. Leave all unchecked unless a game needs one.");
                        font-size: 12px;
                        wrap: word-wrap;
                        color: #888;
                    }
                }
            }

            if !root.editor-can-edit: GroupBox {
                title: @tr("Information");
                vertical-stretch: 1;
                Text {
                    text: @tr("This game has no readable Game ID, so OPL cannot match a metadata file (CFG/<GameID>.cfg). Editing is unavailable for it.");
                    wrap: word-wrap;
                    color: #b58900;
                }
            }

            // Aviso/erro do editor (limite estourado, sem Game ID, falha ao salvar).
            Rectangle {
                height: 20px;
                Text {
                    width: 100%;
                    text: root.editor-note;
                    font-size: 12px;
                    wrap: word-wrap;
                    overflow: elide;
                    color: #d33682;
                }
            }

            HorizontalBox {
                spacing: 8px;
                Button {
                    text: @tr("← Cancel");
                    enabled: !root.busy;
                    clicked => { root.show-game-editor = false; }
                }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: @tr("Save metadata");
                    primary: true;
                    enabled: !root.busy && root.editor-can-edit;
                    clicked => { root.save-game-info-clicked(); }
                }
            }
        }
    }
}
